{
  "type": "object",
  "properties": {
    "ExternalDataProviders": {
      "description": "Named data sources (JSON files, Outlook, APIs) that supply values to documents",
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "$type"
        ],
        "anyOf": [
          {
            "properties": {
              "$type": {
                "const": "Outlook"
              },
              "OutlookAddressbook": {
                "description": "Name of the Outlook address book to query",
                "type": "string"
              },
              "ConnectionSettings": {
                "description": "Connection string for the Outlook data source",
                "type": [
                  "string",
                  "null"
                ]
              },
              "SQLQuery": {
                "description": "DASL query to filter Outlook contacts",
                "type": "string"
              },
              "Timeout": {
                "description": "Maximum time in milliseconds to wait for Outlook data (default: 15000)",
                "type": "integer"
              },
              "ConnectionType": {
                "description": "Data source type (JSON, Outlook, OutlookAddressBookForm)",
                "enum": [
                  "XLSX",
                  "JSON",
                  "Outlook",
                  "OutlookAddressBookForm"
                ],
                "type": "string"
              },
              "FieldAliasOrder": {
                "description": "Maps internal field names to user-friendly display names",
                "type": [
                  "object",
                  "null"
                ]
              },
              "RemoveEmptyRows": {
                "description": "Filters out rows where all selected fields are empty",
                "type": "boolean"
              }
            },
            "required": [
              "OutlookAddressbook"
            ],
            "additionalProperties": false
          },
          {
            "properties": {
              "$type": {
                "const": "JSON"
              },
              "Filename": {
                "description": "Path to the JSON or Excel file (supports environment variables)",
                "type": "string"
              },
              "Timeout": {
                "description": "Maximum time in milliseconds to wait for file load (default: 15000)",
                "type": "integer"
              },
              "SheetList": {
                "description": "Excel sheet names to show or hide (leave empty to show all)",
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "string"
                }
              },
              "ShowHideSheetList": {
                "description": "Whether SheetList defines sheets to \u0027Show\u0027 or \u0027Hide\u0027 (default: \u0027Show\u0027)",
                "type": [
                  "string",
                  "null"
                ]
              },
              "ConnectionType": {
                "description": "Data source type (JSON, Outlook, OutlookAddressBookForm)",
                "enum": [
                  "XLSX",
                  "JSON",
                  "Outlook",
                  "OutlookAddressBookForm"
                ],
                "type": "string"
              },
              "FieldAliasOrder": {
                "description": "Maps internal field names to user-friendly display names",
                "type": [
                  "object",
                  "null"
                ]
              },
              "RemoveEmptyRows": {
                "description": "Filters out rows where all selected fields are empty",
                "type": "boolean"
              }
            },
            "required": [
              "Filename"
            ],
            "additionalProperties": false
          },
          {
            "properties": {
              "$type": {
                "const": "OutlookAddressBookForm"
              },
              "AddressbookName": {
                "description": "Outlook address book name to open in the selection form",
                "type": "string"
              },
              "ContactFieldAliasOrder": {
                "description": "Field aliases for local Outlook contacts",
                "type": [
                  "object",
                  "null"
                ]
              },
              "ExchangeFieldAliasOrder": {
                "description": "Field aliases for Exchange/GAL contacts",
                "type": [
                  "object",
                  "null"
                ]
              },
              "ConnectionType": {
                "description": "Data source type (JSON, Outlook, OutlookAddressBookForm)",
                "enum": [
                  "XLSX",
                  "JSON",
                  "Outlook",
                  "OutlookAddressBookForm"
                ],
                "type": "string"
              },
              "FieldAliasOrder": {
                "description": "Maps internal field names to user-friendly display names",
                "type": [
                  "object",
                  "null"
                ]
              },
              "RemoveEmptyRows": {
                "description": "Filters out rows where all selected fields are empty",
                "type": "boolean"
              }
            },
            "required": [
              "AddressbookName"
            ],
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kutana-brochet.github.io/schemas/7.2/ExternalDataProviderConfiguration.schema.json",
  "title": "ExternalDataProviderConfiguration"
}