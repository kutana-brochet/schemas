{
  "type": "object",
  "properties": {
    "Icons": {
      "description": "Custom icon definitions rendered from text characters using fonts",
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "Name": {
            "description": "Unique identifier for referencing this icon in ribbon XML",
            "type": "string"
          },
          "Text": {
            "description": "Characters to render as the icon (e.g., emoji, symbol, or letter)",
            "type": "string"
          },
          "Size": {
            "description": "Icon dimensions in pixels (creates Size x Size bitmap)",
            "type": "integer"
          },
          "FontName": {
            "description": "Font family name for rendering the text (e.g., \u0027Segoe UI Symbol\u0027)",
            "type": "string"
          },
          "FontSize": {
            "description": "Font size in pixels for the rendered text",
            "type": "integer"
          },
          "FontStyles": {
            "description": "Font styling (Regular, Bold, Italic, etc.)",
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "Regular",
                "Bold",
                "Italic",
                "Underline",
                "Strikeout"
              ]
            }
          },
          "FontColour": {
            "description": "Text colour as hex RGB (\u0027#FF0000\u0027) or named colour (default: \u0027Black\u0027)",
            "type": "string"
          },
          "XOffset": {
            "description": "Horizontal offset in pixels for positioning the text",
            "type": "integer"
          },
          "YOffset": {
            "description": "Vertical offset in pixels for positioning the text",
            "type": "integer"
          },
          "TextRenderingHint": {
            "description": "Text rendering quality (AntiAlias, ClearType, etc.)",
            "enum": [
              "SystemDefault",
              "SingleBitPerPixelGridFit",
              "SingleBitPerPixel",
              "AntiAliasGridFit",
              "AntiAlias",
              "ClearTypeGridFit"
            ],
            "type": "string"
          },
          "Bitmap": {
            "type": [
              "object",
              "null"
            ],
            "properties": {
              "Tag": true,
              "PhysicalDimension": {
                "type": "object",
                "properties": {
                  "IsEmpty": {
                    "type": "boolean"
                  },
                  "Width": {
                    "type": "number"
                  },
                  "Height": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              },
              "Size": {
                "type": "object",
                "properties": {
                  "IsEmpty": {
                    "type": "boolean"
                  },
                  "Width": {
                    "type": "integer"
                  },
                  "Height": {
                    "type": "integer"
                  }
                },
                "additionalProperties": false
              },
              "Width": {
                "type": "integer"
              },
              "Height": {
                "type": "integer"
              },
              "HorizontalResolution": {
                "type": "number"
              },
              "VerticalResolution": {
                "type": "number"
              },
              "Flags": {
                "type": "integer"
              },
              "RawFormat": {
                "type": [
                  "object",
                  "null"
                ],
                "properties": {
                  "Guid": {
                    "type": "string",
                    "format": "uuid"
                  }
                },
                "required": [
                  "Guid"
                ],
                "additionalProperties": false
              },
              "PixelFormat": {
                "enum": [
                  "DontCare",
                  "Undefined",
                  "Max",
                  "Indexed",
                  "Gdi",
                  "Format16bppRgb555",
                  "Format16bppRgb565",
                  "Format24bppRgb",
                  "Format32bppRgb",
                  "Format1bppIndexed",
                  "Format4bppIndexed",
                  "Format8bppIndexed",
                  "Alpha",
                  "Format16bppArgb1555",
                  "PAlpha",
                  "Format32bppPArgb",
                  "Extended",
                  "Format16bppGrayScale",
                  "Format48bppRgb",
                  "Format64bppPArgb",
                  "Canonical",
                  "Format32bppArgb",
                  "Format64bppArgb"
                ],
                "type": "string"
              },
              "PropertyIdList": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "integer"
                }
              },
              "PropertyItems": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "object",
                  "properties": {
                    "Id": {
                      "type": "integer"
                    },
                    "Len": {
                      "type": "integer"
                    },
                    "Type": {
                      "type": "integer"
                    },
                    "Value": {
                      "type": [
                        "string",
                        "null"
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              },
              "Palette": {
                "type": "object",
                "properties": {
                  "Flags": {
                    "type": "integer"
                  },
                  "Entries": {
                    "type": [
                      "array",
                      "null"
                    ],
                    "items": {
                      "type": "object",
                      "properties": {
                        "R": {
                          "type": "integer"
                        },
                        "G": {
                          "type": "integer"
                        },
                        "B": {
                          "type": "integer"
                        },
                        "A": {
                          "type": "integer"
                        },
                        "IsKnownColor": {
                          "type": "boolean"
                        },
                        "IsEmpty": {
                          "type": "boolean"
                        },
                        "IsNamedColor": {
                          "type": "boolean"
                        },
                        "IsSystemColor": {
                          "type": "boolean"
                        },
                        "Name": {
                          "type": [
                            "string",
                            "null"
                          ]
                        }
                      },
                      "additionalProperties": false
                    }
                  }
                },
                "additionalProperties": false
              },
              "FrameDimensionsList": {
                "type": [
                  "array",
                  "null"
                ],
                "items": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            },
            "additionalProperties": false
          }
        },
        "required": [
          "Name",
          "Text",
          "Size",
          "FontName",
          "FontSize",
          "XOffset",
          "YOffset"
        ],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kutana-brochet.github.io/schemas/7.2/RibbonIconsConfiguration.schema.json",
  "title": "RibbonIconsConfiguration"
}